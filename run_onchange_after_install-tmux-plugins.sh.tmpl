#!/usr/bin/env bash
# Bootstrap TPM and install/update tmux plugins (dracula, tmux-sensible, ...).
# Re-runs whenever tmux.conf changes, because the hash below changes with it:
# tmux.conf hash: {{ include "dot_config/tmux/tmux.conf" | sha256sum }}
set -euo pipefail

TPM_DIR="$HOME/.config/tmux/plugins/tpm"

if ! command -v tmux >/dev/null 2>&1; then
	echo "tmux not installed; skipping plugin setup"
	exit 0
fi

# TPM is what the last line of tmux.conf runs; without it tmux exits 127 and no
# plugins load. Clone it on first run / on a fresh remote machine.
if [ ! -d "$TPM_DIR" ]; then
	echo "Installing TPM into $TPM_DIR"
	git clone --depth 1 https://github.com/tmux-plugins/tpm "$TPM_DIR"
fi

# TPM reads its plugin path only from the tmux server env var, which normally
# gets set by the tpm line in tmux.conf running inside a live session. On a
# headless apply that never happens, so install_plugins aborts with
# "unknown variable: TMUX_PLUGIN_MANAGER_PATH". Set it ourselves (TPM's own XDG
# default): exporting it lets the server TPM spawns inherit it; the
# set-environment covers an already-running server.
export TMUX_PLUGIN_MANAGER_PATH="$HOME/.config/tmux/plugins/"
tmux start-server 2>/dev/null || true
tmux set-environment -g TMUX_PLUGIN_MANAGER_PATH "$TMUX_PLUGIN_MANAGER_PATH" 2>/dev/null || true

# install_plugins / update_plugins read the plugin list from tmux.conf on disk,
# so no live session is needed beyond the env var above.
echo "Installing tmux plugins"
"$TPM_DIR/bin/install_plugins"
echo "Updating tmux plugins"
"$TPM_DIR/bin/update_plugins" all

# Reload config in any already-running sessions so the theme applies now.
if tmux info >/dev/null 2>&1; then
	echo "Reloading tmux config in running server"
	tmux source-file "$HOME/.config/tmux/tmux.conf"
fi
