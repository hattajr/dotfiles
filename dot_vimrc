" Line numbers
set number
set relativenumber

" Indentation
set tabstop=4
set shiftwidth=4
set expandtab
set smartindent

" Search
set ignorecase
set smartcase
set incsearch
set hlsearch

" Better editing
set nowrap
set scrolloff=8
set clipboard=unnamedplus
set mouse=a

" UI
syntax on
set cursorline
