#!/usr/bin/env bash
# Writes ~/.pi/agent/auth.json from Bitwarden secure note "pi-auth-json".
# Runs after externals (so ~/.pi/ exists from git clone).
# Re-runs when the rendered content (the secret) changes.
# Requires: bw CLI installed and unlocked (BW_SESSION exported).
set -euo pipefail

mkdir -p "$HOME/.pi/agent"
content="$(cat <<'PI_AUTH_EOF'
{{ (bitwarden "item" "pi-auth-json").notes }}
PI_AUTH_EOF
)"
printf '%s' "$content" > "$HOME/.pi/agent/auth.json"
chmod 600 "$HOME/.pi/agent/auth.json"
